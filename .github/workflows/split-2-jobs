name: split-jobs

on:
  pull_request:
    branches:
      - main
    types:
      - opened
      - reopened
      - synchronize
  workflow_dispatch:

jobs:
  # ─── JOB 1: Test, Lint, Scan Code ───────────────────────────
  run-tests:
    runs-on: ${{ matrix.os }}
    strategy:
      matrix:
        os: [ubuntu-latest]
        version: ["3.11", "3.12"]

    steps:
      - name: Check out repository
        uses: actions/checkout@v4

      - name: Validate checkout
        run: ls -a

      - name: Run Trivy filesystem scanner
        uses: aquasecurity/trivy-action@v0.36.0
        with:
          scan-type: 'fs'
          scan-ref: '.'
          format: 'table'
          exit-code: '1'
          ignore-unfixed: true
          severity: 'CRITICAL,HIGH'

      - name: Run Trivy config scanner
        uses: aquasecurity/trivy-action@master
        with:
          scan-type: 'config'
          hide-progress: true
          exit-code: '0'
          severity: 'CRITICAL,HIGH'

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: ${{ matrix.version }}

      - name: Validate Python is installed
        run: python --version

      - name: Lint with Ruff
        run: |
          pip install ruff
          ruff check ./app/

      - name: Run tests
        run: python -m unittest discover -s tests -v

      - name: Get current time
        run: |
          NOW=$(date +'%Y-%m-%d %H:%M:%S')
          echo "NOW=$NOW" >> $GITHUB_ENV
          echo "Current time is: $NOW"

  # ─── JOB 2: Build, Scan Image, Push to ECR ──────────────────
  build-and-push:
    runs-on: ubuntu-latest
    needs: run-tests    
    steps:
      - name: Check out repository
        uses: actions/checkout@v4

      - name: Build Docker image
        run: docker build -t docker.io/ahmedyasser02/my-app:${{ github.sha }} .

      - name: Save Docker image as tar
        run: docker save docker.io/ahmedyasser02/my-app:${{ github.sha }} -o my-app.tar

      - name: Upload Docker image artifact
        uses: actions/upload-artifact@v4
        with:
          name: docker-image-${{ matrix.version }}
          path: my-app.tar
          retention-days: 7

      - name: Run Trivy image scanner
        uses: aquasecurity/trivy-action@v0.36.0
        with:
          image-ref: 'docker.io/ahmedyasser02/my-app:${{ github.sha }}'
          format: 'json'
          output: 'trivy-image-report.json'
          exit-code: '1'
          ignore-unfixed: true
          vuln-type: 'os,library'
          severity: 'CRITICAL,HIGH'

      - name: Upload Trivy scan report artifact
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: trivy-report-${{ matrix.version }}
          path: trivy-image-report.json
          retention-days: 7

      - name: Configure AWS credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
          aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
          aws-region: ${{ secrets.AWS_REGION }}

      - name: Log in to Amazon ECR
        uses: aws-actions/amazon-ecr-login@v2

      - name: Push image to ECR
        run: |
          docker tag docker.io/ahmedyasser02/my-app:${{ github.sha }} \
            ${{ secrets.ECR_REGISTRY }}/${{ secrets.ECR_REPOSITORY }}:${{ github.sha }}
          docker push ${{ secrets.ECR_REGISTRY }}/${{ secrets.ECR_REPOSITORY }}:${{ github.sha }}
